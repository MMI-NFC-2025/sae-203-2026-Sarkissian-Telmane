---
import Logo from "../assets/icons/logo.svg";
---

<header class="bg-dark">
    <div
        class="flex items-center justify-between h-28 px-6 lg:flex-col lg:items-start lg:justify-center"
    >
        <a class="scale-50" href="/"><Logo /></a>

        <button
            class="group relative w-7.5 h-6 lg:hidden"
            aria-label="Menu"
            aria-expanded="false"
            id="menuButton"
        >
            <span
                class="absolute top-0 left-0 w-full h-0.5 rounded transition-all duration-300 group-aria-expanded:top-1/2 group-aria-expanded:-translate-y-1/2 group-aria-expanded:rotate-45 bg-white"
            ></span>

            <span
                class="absolute top-1/2 left-0 w-full h-0.5 rounded -translate-y-1/2 transition-all duration-300 group-aria-expanded:opacity-0 bg-white"
            ></span>

            <span
                class="absolute bottom-0 left-0 w-full h-0.5 rounded transition-all duration-300 group-aria-expanded:bottom-1/2 group-aria-expanded:translate-y-1/2 group-aria-expanded:-rotate-45 bg-white"
            ></span>
        </button>
    </div>
    <div class="lg:pb-5">
        <nav
            id="menu"
            class="bg-dark hidden lg:flex lg:items-center lg:justify-center"
        >
            <ul
                class="px-6 py-6 lg:flex lg:gap-5 lg:items-center lg:py-0 lg:justify-center"
            >
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Festival</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Programmation</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Artistes</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Scènes</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Infos pratiques</a
                    >
                </li>
                <li>
                    <a
                        href="#"
                        class="font-serif text-[2rem] mb-3.75 block transition-colors hover:text-light1 lg:text-base lg:mb-0"
                        >Contact</a
                    >
                </li>
            </ul>
            <div class="flex justify-center lg:justify-end lg:ml-20">
                <form
                    id="siteSearchForm"
                    class="bg-white flex justify-between w-1/3 rounded-2xl mb-24 lg:w-50 lg:mb-0"
                >
                    <input
                        type="text"
                        id="siteSearchInput"
                        placeholder="Que cherchez-vous ?"
                        class="text-light1 w-full ml-3"
                    />
                    <button
                        type="submit"
                        aria-label="Rechercher"
                        class="stroke-light1 mr-3"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><line
                                x1="21"
                                y1="21"
                                x2="16.65"
                                y2="16.65"></line></svg
                        >
                    </button>
                </form>
                <p
                    id="searchError"
                    style="color: #ff0000; font-size: 0.9rem; display: none; margin-top: 5px;"
                >
                    Aucune page trouvée pour ce mot.
                </p>
            </div>
        </nav>
    </div>
    <script>
        const button = document.getElementById("menuButton");
        const menu = document.getElementById("menu");

        if (button && menu) {
            button.addEventListener("click", () => {
                const expanded =
                    button.getAttribute("aria-expanded") === "true";

                button.setAttribute("aria-expanded", (!expanded).toString());
                menu.classList.toggle("hidden");
            });
        }
    </script>
</header>
